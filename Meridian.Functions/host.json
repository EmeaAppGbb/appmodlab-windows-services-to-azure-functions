{
  "version": "2.0",
  "functionTimeout": "00:10:00",
  "logging": {
    "logLevel": {
      "default": "Information",
      "Microsoft": "Warning",
      "System": "Warning",
      "Meridian.Functions": "Information"
    },
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "maxTelemetryItemsPerSecond": 20,
        "excludedTypes": "Request;Dependency",
        "includedTypes": "Event;Trace;Exception"
      },
      "enableLiveMetricsFilters": true,
      "enableDependencyTracking": true
    }
  }
}
