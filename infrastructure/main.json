              "defaultValue": "DoNotReply@meridian.com",
              "metadata": {
                "description": "Sender email address for Azure Communication Services"
              }
            },
            "complianceNotificationEmail": {
              "type": "string",
              "defaultValue": "compliance@meridian.com",
              "metadata": {
                "description": "Email address for compliance notifications"
              }
            },
            "dailyReturnThreshold": {
              "type": "string",
              "defaultValue": "0.05",
              "metadata": {
                "description": "Daily return threshold for portfolio valuation alerts"
              }
            }
          },
          "variables": {
            "functionAppName": "[format('func-{0}', parameters('baseName'))]",
            "hostingPlanName": "[format('plan-{0}', parameters('baseName'))]"
          },
          "resources": [
            {
              "type": "Microsoft.Web/serverfarms",
              "apiVersion": "2023-12-01",
              "name": "[variables('hostingPlanName')]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]",
              "sku": {
                "name": "Y1",
                "tier": "Dynamic"
              },
              "properties": {}
            },
            {
              "type": "Microsoft.Web/sites",
              "apiVersion": "2023-12-01",
              "name": "[variables('functionAppName')]",
              "location": "[parameters('location')]",
              "tags": "[union(parameters('tags'), createObject('azd-service-name', 'meridian-functions'))]",
              "kind": "functionapp",
              "identity": {
                "type": "SystemAssigned"
              },
              "properties": {
                "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('hostingPlanName'))]",
                "httpsOnly": true,
                "siteConfig": {
                  "ftpsState": "Disabled",
                  "minTlsVersion": "1.2",
                  "netFrameworkVersion": "v9.0",
                  "use32BitWorkerProcess": false,
                  "appSettings": [
                    {
                      "name": "AzureWebJobsStorage",
                      "value": "[parameters('storageConnectionString')]"
                    },
                    {
                      "name": "WEBSITE_CONTENTAZUREFILECONNECTIONSTRING",
                      "value": "[parameters('storageConnectionString')]"
                    },
                    {
                      "name": "WEBSITE_CONTENTSHARE",
                      "value": "[toLower(variables('functionAppName'))]"
                    },
                    {
                      "name": "FUNCTIONS_EXTENSION_VERSION",
                      "value": "~4"
                    },
                    {
                      "name": "FUNCTIONS_WORKER_RUNTIME",
                      "value": "dotnet-isolated"
                    },
                    {
                      "name": "APPINSIGHTS_INSTRUMENTATIONKEY",
                      "value": "[parameters('appInsightsInstrumentationKey')]"
                    },
                    {
                      "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
                      "value": "[parameters('appInsightsConnectionString')]"
                    },
                    {
                      "name": "SqlConnectionString",
                      "value": "[parameters('sqlConnectionString')]"
                    },
                    {
                      "name": "AzureCommunicationServicesConnectionString",
                      "value": "[parameters('communicationServicesConnectionString')]"
                    },
                    {
                      "name": "AzureCommunicationServicesSenderAddress",
                      "value": "[parameters('communicationServicesSenderAddress')]"
                    },
                    {
                      "name": "ComplianceNotificationEmail",
                      "value": "[parameters('complianceNotificationEmail')]"
                    },
                    {
                      "name": "DailyReturnThreshold",
                      "value": "[parameters('dailyReturnThreshold')]"
                    }
                  ]
                }
              },
              "dependsOn": [
                "[resourceId('Microsoft.Web/serverfarms', variables('hostingPlanName'))]"
              ]
            }
          ],
          "outputs": {
            "functionAppName": {
              "type": "string",
              "metadata": {
                "description": "Function App name"
              },
              "value": "[variables('functionAppName')]"
            },
            "defaultHostName": {
              "type": "string",
              "metadata": {
                "description": "Function App default hostname"
              },
              "value": "[reference(resourceId('Microsoft.Web/sites', variables('functionAppName')), '2023-12-01').defaultHostName]"
            },
            "functionAppId": {
              "type": "string",
              "metadata": {
                "description": "Function App resource ID"
              },
              "value": "[resourceId('Microsoft.Web/sites', variables('functionAppName'))]"
            },
            "principalId": {
              "type": "string",
              "metadata": {
                "description": "Function App managed identity principal ID"
              },
              "value": "[reference(resourceId('Microsoft.Web/sites', variables('functionAppName')), '2023-12-01', 'full').identity.principalId]"
            }
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Resources/deployments', format('monitoring-{0}', parameters('environmentName')))]",
        "[resourceId('Microsoft.Resources/deployments', format('sql-{0}', parameters('environmentName')))]",
        "[resourceId('Microsoft.Resources/deployments', format('storage-{0}', parameters('environmentName')))]"
      ]
    }
  ],
  "outputs": {
    "functionAppName": {
      "type": "string",
      "metadata": {
        "description": "Function App name"
      },
      "value": "[reference(resourceId('Microsoft.Resources/deployments', format('function-app-{0}', parameters('environmentName'))), '2025-04-01').outputs.functionAppName.value]"
    },
    "functionAppUrl": {
      "type": "string",
      "metadata": {
        "description": "Function App URL"
      },
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Resources/deployments', format('function-app-{0}', parameters('environmentName'))), '2025-04-01').outputs.defaultHostName.value)]"
    },
    "storageAccountName": {
      "type": "string",
      "metadata": {
        "description": "Storage Account name"
      },
      "value": "[reference(resourceId('Microsoft.Resources/deployments', format('storage-{0}', parameters('environmentName'))), '2025-04-01').outputs.storageAccountName.value]"
    },
    "sqlServerFqdn": {
      "type": "string",
      "metadata": {
        "description": "SQL Server FQDN"
      },
      "value": "[reference(resourceId('Microsoft.Resources/deployments', format('sql-{0}', parameters('environmentName'))), '2025-04-01').outputs.sqlServerFqdn.value]"
    },
    "applicationInsightsId": {
      "type": "string",
      "metadata": {
        "description": "Application Insights resource ID"
      },
      "value": "[reference(resourceId('Microsoft.Resources/deployments', format('monitoring-{0}', parameters('environmentName'))), '2025-04-01').outputs.applicationInsightsId.value]"
    },
    "communicationServicesName": {
      "type": "string",
      "metadata": {
        "description": "Communication Services name"
      },
      "value": "[format('acs-{0}', variables('baseName'))]"
    }
  }
}